# Neon PostgreSQL (get from console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# TMDB API Key (get free from themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# JWT Secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-with-a-secure-random-string-at-least-32-chars

# Admin setup (used only on /api/setup first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# Public site config
NEXT_PUBLIC_SITE_URL=https://fmoviesz.cyou
NEXT_PUBLIC_SITE_NAME=Fmovies
