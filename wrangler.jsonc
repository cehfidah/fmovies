{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fmovies",
  "main": "./worker.ts",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": [
      "0 6 * * *",
      "0 8 * * *"
    ]
  }
}